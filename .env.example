# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# Get your free key at: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Any random string — used to sign Flask sessions
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# Only needed if your network uses a proxy server (e.g. university networks)
# HTTP_PROXY=http://proxy-host:port
# HTTPS_PROXY=http://proxy-host:port
